@startuml Hackerlith - Diagrama de Clases MVC

skinparam backgroundColor #1a1a1a
skinparam classBackgroundColor #2a2a2a
skinparam classBorderColor #666666
skinparam classHeaderBackgroundColor #3a3a3a
skinparam fontColor #ffffff
skinparam arrowColor #aaaaaa
skinparam packageBackgroundColor #1f1f1f
skinparam packageBorderColor #555555
skinparam classFontColor #ffffff
skinparam classAttributeFontColor #cccccc

title Hackerlith - Patron MVC

' ============ MODELO ============
package "Modelo (model)" #1f2f1f {

    class Juego {
        - tablero : Tablero
        - jugador : Jugador
        - paquete : PaqueteDatos
        - puertos : Puerto[]
        - amenazas : Amenaza[]
        - nodos : NodoEnergia[]
        - estado : String
        - movimientosMax : int
        - ordenInverso : boolean
        - dificultad : String
        --
        + Juego(filas, columnas, numPuertos, movMax, ordenInverso)
        + inicializar(dificultad : String) : void
        + verificarVictoria() : boolean
        + verificarDerrota() : boolean
        + moverAmenazas() : void
        + getEstado() : String
        + setEstado(estado : String) : void
        + getDificultad() : String
        + getMovimientosMax() : int
        + isOrdenInverso() : boolean
    }

    class Tablero {
        - filas : int
        - columnas : int
        - celdas : String[][]
        --
        + Tablero(filas, columnas)
        + getCelda(fila, columna) : String
        + setCelda(fila, columna, valor) : void
        + estaEnRango(fila, columna) : boolean
        + getFilas() : int
        + getColumnas() : int
    }

    class Jugador {
        - fila : int
        - columna : int
        - movimientosRestantes : int
        - modoSigilo : boolean
        - sigiloUsado : boolean
        --
        + Jugador(fila, columna, movimientos)
        + getFila() : int
        + getColumna() : int
        + getMovimientosRestantes() : int
        + isModoSigilo() : boolean
        + isSigiloUsado() : boolean
        + setFila(fila : int) : void
        + setColumna(columna : int) : void
        + setMovimientosRestantes(mov : int) : void
        + setModoSigilo(b : boolean) : void
        + setSigiloUsado(b : boolean) : void
    }

    class PaqueteDatos {
        - fila : int
        - columna : int
        - puertosVisitados : int
        - rastro : int[][]
        - cantidadRastro : int
        --
        + PaqueteDatos(fila, columna)
        + getFila() : int
        + getColumna() : int
        + getPuertosVisitados() : int
        + visitarPuerto() : void
        + agregarRastro(fila, columna) : void
        + getRastro() : int[][]
        + getCantidadRastro() : int
        + setFila(fila : int) : void
        + setColumna(columna : int) : void
    }

    class Puerto {
        - fila : int
        - columna : int
        - numero : int
        - visitado : boolean
        --
        + Puerto(fila, columna, numero)
        + getFila() : int
        + getColumna() : int
        + getNumero() : int
        + isVisitado() : boolean
        + setVisitado(v : boolean) : void
    }

    class Amenaza {
        - fila : int
        - columna : int
        - tipo : String
        --
        + Amenaza(fila, columna, tipo)
        + mover(tablero : Tablero) : void
        + getFila() : int
        + getColumna() : int
        + getTipo() : String
        + setFila(fila : int) : void
        + setColumna(columna : int) : void
    }

    class NodoEnergia {
        - fila : int
        - columna : int
        - activo : boolean
        --
        + NodoEnergia(fila, columna)
        + getFila() : int
        + getColumna() : int
        + isActivo() : boolean
        + setActivo(activo : boolean) : void
    }
}

' ============ CONTROLADOR ============
package "Controlador (controller)" #1f1f2f {

    class Controlador {
        - juego : Juego
        - historial : ArrayList<String>
        - turno : int
        --
        + Controlador(dificultad, ordenInverso, filas, columnas, numPuertos)
        + moverJugador(direccion : String) : void
        + guardarLog() : void
        + getJuego() : Juego
        - verificarEncuentros() : void
        - verificarNodos() : void
        - verificarSandwichFirewall() : void
    }
}

' ============ VISTA ============
package "Vista (view)" #2f1f1f {

    class VentanaPrincipal {
        - cardLayout : CardLayout
        - contenedor : JPanel
        - panelMenu : PanelMenu
        - panelJuego : PanelJuego
        - panelJuegoCompleto : JPanel
        - controlador : Controlador
        - audio : GestorAudio
        --
        + VentanaPrincipal()
        - iniciarJuego() : void
        - reiniciarJuego() : void
        - volverAlMenu() : void
        - mostrarMenuPausa() : void
        - verObjetivos(dialogo) : void
        - verInstruccionesConPenalizacion(dialogo) : void
    }

    class PanelMenu {
        - dificultad : String
        - ordenInverso : boolean
        - skin : String
        - filas : int
        - columnas : int
        - numPuertos : int
        --
        + PanelMenu()
        + getDificultad() : String
        + isOrdenInverso() : boolean
        + getSkin() : String
        + getFilas() : int
        + getColumnas() : int
        + getNumPuertos() : int
        + getBtnNuevaPartida() : JButton
    }

    class PanelJuego {
        - juego : Juego
        - onVolverMenu : Runnable
        - direccionJugador : String
        --
        + PanelJuego(juego : Juego, skin : String)
        + actualizar() : void
        + setDireccionJugador(dir : String) : void
        + setOnVolverMenu(r : Runnable) : void
        # paintComponent(g : Graphics) : void
    }

    class PanelInfo {
        - juego : Juego
        - dificultad : String
        --
        + PanelInfo(juego : Juego, dificultad : String)
        # paintComponent(g : Graphics) : void
    }

    class GestorAudio {
        - clipActual : Clip
        --
        + reproducir(ruta : String, loop : boolean) : void
        + detener() : void
    }
}

' ============ RELACIONES ============

' Juego contiene a los demás modelos (composicion)
Juego *-- Tablero
Juego *-- Jugador
Juego *-- PaqueteDatos
Juego *-- "2..*" Puerto
Juego *-- "0..*" Amenaza
Juego *-- "0..*" NodoEnergia

' Amenaza usa Tablero para moverse
Amenaza ..> Tablero : usa

' Controlador gestiona el Juego
Controlador *-- Juego

' VentanaPrincipal coordina todo
VentanaPrincipal *-- Controlador
VentanaPrincipal *-- PanelMenu
VentanaPrincipal *-- PanelJuego
VentanaPrincipal *-- GestorAudio

' PanelJuego y PanelInfo observan el Juego
PanelJuego ..> Juego : observa
PanelInfo ..> Juego : observa

@enduml
